{
  "name": "pi-study-helper",
  "version": "0.1.0",

  "description": "Pi Study Helper — Task-driven study assistant organized by Loop Graph SDK for learning sessions, reviews, and profile management",
  "private": true,
  "keywords": [
    "pi-package"
  ],
  "files": [
    "src",
    "fixtures/profiles",
    "LICENSE",
    "README.md"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CYM2006CYM/optimized-pi-review-agent-with-sdk.git"
  },
  "homepage": "https://github.com/CYM2006CYM/optimized-pi-review-agent-with-sdk#readme",
  "bugs": {
    "url": "https://github.com/CYM2006CYM/optimized-pi-review-agent-with-sdk/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "main": "./src/extension/index.ts",
  "pi": {
    "extensions": [
      "./src/extension/index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json",
    "test": "vitest run",
    "check:docs": "node scripts/check-doc-links.mjs",
    "check:release": "node scripts/check-release.mjs",
    "check:history": "node scripts/check-history.mjs",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "audit:all": "npm audit --audit-level=high",
    "verify": "npm run typecheck && npm test && npm run check:docs && npm run smoke:extension && npm run check:release",
    "verify:open-source": "npm run verify && npm run check:history && npm run audit:prod && npm run audit:all && npm pack --dry-run",
    "smoke:extension": "node scripts/smoke-extension.mjs",
    "probe:sdk-agent": "node scripts/run-sdk-agent-probe.mjs"
  },
  "dependencies": {
    "pi-loop-graph-sdk": "github:0liveiraaa/pi-loop-graph-sdk#ecb8d83"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.3",
    "@earendil-works/pi-tui": "0.80.3",
    "typebox": "1.3.5",
    "typescript": "^5.5.0",
    "vitest": "^4.1.10"
  }
}
